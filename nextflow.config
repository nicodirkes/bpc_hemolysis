
workDir = '.work'

// main.nf declares each module's *intent* (a conda `environment.yml`, or a
// `container` for image-native modules like model_julia). The wiring that turns
// that intent into a reproducible install lives here, driven by params:
//   default             -> conda, installed from the committed platform lock file
//   --useLockFiles false -> conda, solving environment.yml at runtime
//   --containerized      -> ignore conda, run every module from its pushed image
// (Helpers are params-held closures: Nextflow's config parser forbids top-level
//  method definitions.)

params {
    // Cap on the CPUs this workflow may use for concurrency (maxForks).
    // null  -> use every core the machine reports.
    // Override per run with --max_cpus 16, or per profile (see `cluster`).
    max_cpus = null

    // Conda environment resolution.
    // useLockFiles: true -> install from the committed per-platform lock files
    //   under <module>/lockfile/ (reproducible, no solve). false -> solve each
    //   <module>/environment.yml at runtime.
    // lockPlatform: which committed lock to use; auto-detected from the host,
    //   override with --lockPlatform (linux-64|linux-aarch64|osx-64|osx-arm64|win-64).
    // condaEngine: conda by default.
    useLockFiles = true
    lockPlatform = {
        def os   = System.getProperty('os.name').toLowerCase()
        def arch = System.getProperty('os.arch').toLowerCase()
        def arm  = arch in ['aarch64', 'arm64']
        (os.contains('mac') || os.contains('darwin')) ? (arm ? 'osx-arm64' : 'osx-64')
            : os.contains('windows')                  ? 'win-64'
            : (arm ? 'linux-aarch64' : 'linux-64')
    }()
    condaEngine = 'conda'

    // Containerized execution: run every module from its pushed GHCR image
    // instead of conda. Enable with --containerized. Modules that could not be
    // locked (pip deps, e.g. model/mcmc) are only reproducible this way.
    containerized = false
    imageRepo     = 'ghcr.io/nicodirkes/bpc_hemolysis'
    imageTag      = 'latest'

    // Internal resolvers (see the withName overrides below). Take a module name.
    // conda spec: platform lock when locked (and requested), else environment.yml;
    // null under --containerized so conda is left unset.
    condaFor = { module ->
        if (params.containerized) return null
        def envYml = "${projectDir}/${module}/environment.yml"
        if (!params.useLockFiles) return envYml
        def lock = "${projectDir}/${module}/lockfile/conda-${params.lockPlatform}.lock"
        new File(lock as String).exists() ? lock : envYml
    }
    // GHCR image under --containerized, else null so container is left unset.
    containerFor = { module ->
        params.containerized ? "${params.imageRepo}/${module}:${params.imageTag}" : null
    }
}

process {
    withName: 'SERVE_MODEL_JL|SERVE_MODEL_PY|MCMC_CALIBRATION' {
        maxForks = {
            try {
                def cfg = new groovy.yaml.YamlSlurper().parseText(new File(params.config_file).text) as Map
                def nModel = (cfg.model?.n_workers ?: 1) as int
                def nCalib = (cfg.calibration?.n_workers ?: 1) as int
                def budget = params.max_cpus ? (params.max_cpus as int)
                                             : Runtime.runtime.availableProcessors()
                Math.max(1, (int)(budget / (nModel + nCalib)))
            } catch (Exception ignored) { 1 }
        }()
    }

    // Per-module env resolution. Each closure returns a value or null; a null
    // directive is left unset, so a module runs via conda XOR its container.
    // model_julia (SERVE_MODEL_JL) is image-native — its container stays in main.nf.
    withName: PULL_DATA_COSCINE { conda = { params.condaFor('pull_data') };     container = { params.containerFor('pull_data') } }
    withName: PREPROCESS_DATA   { conda = { params.condaFor('preprocessing') }; container = { params.containerFor('preprocessing') } }
    withName: SERVE_MODEL_PY    { conda = { params.condaFor('model') };         container = { params.containerFor('model') } }
    withName: MCMC_CALIBRATION  { conda = { params.condaFor('mcmc') };          container = { params.containerFor('mcmc') } }
    withName: RUN_DIAGNOSTICS   { conda = { params.condaFor('diagnostics') };   container = { params.containerFor('diagnostics') } }
    withName: GENERATE_REPORT   { conda = { params.condaFor('report') };        container = { params.containerFor('report') } }
    withName: GENERATE_EXPERIMENTS { conda = { params.condaFor('experiments') }; container = { params.containerFor('experiments') } }
}

// Conda is off under --containerized (every module runs from its image instead).
conda.enabled       = !params.containerized
conda.useMamba      = params.condaEngine == 'mamba'
conda.useMicromamba = params.condaEngine == 'micromamba'

// Container engine default (applies when no -profile is given) -> local / Docker.
docker.enabled = true

profiles {
    // Local workstation: Docker. Mirrors the default above; kept explicit so
    // `-profile local` is a valid, self-documenting choice.
    local {
        docker.enabled    = true
        apptainer.enabled = false
    }

    // Shared cluster node: Apptainer instead of Docker. Process execution stays
    // on the local executor for now (no batch scheduler). Caps CPU use so the
    // workflow is a good citizen on a shared node.
    cluster {
        docker.enabled       = false
        apptainer.enabled    = true
        apptainer.autoMounts = true
        // On a shared node the auto-detected core count is the whole machine,
        // not your share of it. Respect NXF_MAX_CPUS if the environment sets it
        // (module/login setup, interactive allocation); otherwise fall back to a
        // conservative value. This is a *total* budget shared across concurrent
        // experiments: each consumes model.n_workers + calibration.n_workers
        // cores (2 with the params.yml defaults), so 8 -> up to 4 in parallel.
        // Override per run with --max_cpus.
        params.max_cpus = (System.getenv('NXF_MAX_CPUS') ?: '8') as int
    }
}
