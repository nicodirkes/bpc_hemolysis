
workDir = '.work'

params {
    // Cap on the CPUs this workflow may use for concurrency (maxForks).
    // null  -> use every core the machine reports.
    // Override per run with --max_cpus 16, or per profile (see `cluster`).
    max_cpus = null
}

process {
    withName: 'SERVE_MODEL_JL|SERVE_MODEL_PY|MCMC_CALIBRATION' {
        maxForks = {
            try {
                def cfg = new groovy.yaml.YamlSlurper().parseText(new File(params.config_file).text) as Map
                def nModel = (cfg.model?.n_workers ?: 1) as int
                def nCalib = (cfg.calibration?.n_workers ?: 1) as int
                def budget = params.max_cpus ? (params.max_cpus as int)
                                             : Runtime.runtime.availableProcessors()
                Math.max(1, (int)(budget / (nModel + nCalib)))
            } catch (Exception ignored) { 1 }
        }()
    }
}

conda.enabled = true
// conda.useMicromamba = true

// Container engine default (applies when no -profile is given) -> local / Docker.
docker.enabled = true

profiles {
    // Local workstation: Docker. Mirrors the default above; kept explicit so
    // `-profile local` is a valid, self-documenting choice.
    local {
        docker.enabled    = true
        apptainer.enabled = false
        process { withName: SERVE_MODEL_JL { container = 'bpc_hemolysis/model_julia' } }
    }

    // Shared cluster node: Apptainer instead of Docker. Process execution stays
    // on the local executor for now (no batch scheduler). Caps CPU use so the
    // workflow is a good citizen on a shared node.
    cluster {
        docker.enabled       = false
        apptainer.enabled    = true
        apptainer.autoMounts = true
        // On a shared node the auto-detected core count is the whole machine,
        // not your share of it. Respect NXF_MAX_CPUS if the environment sets it
        // (module/login setup, interactive allocation); otherwise fall back to a
        // conservative value. This is a *total* budget shared across concurrent
        // experiments: each consumes model.n_workers + calibration.n_workers
        // cores (2 with the params.yml defaults), so 8 -> up to 4 in parallel.
        // Override per run with --max_cpus.
        params.max_cpus = (System.getenv('NXF_MAX_CPUS') ?: '8') as int
        process { withName: SERVE_MODEL_JL { container = "file://$projectDir/model_julia/container.sif" } }
    }
}